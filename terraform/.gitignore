# Local Terraform working files — state lives remotely in S3, never commit
# a local copy or provider caches.
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
override.tf
override.tf.json
.terraformrc
terraform.rc

# The dependency lock file IS committed on purpose, so every apply (local
# or CI) resolves the exact same provider versions:
# !.terraform.lock.hcl

# Partial backend config: embeds the AWS account id in the state bucket
# name, so it's supplied locally/in CI via -backend-config and never
# committed. backend.hcl.example (the placeholder template) IS committed.
backend.hcl

# Console-user real names (PRD platform/0007): already covered by the
# blanket "*.tfvars"/"*.tfvars.json" ignores above, but named explicitly
# here too since these usernames must never land in a committed file.
# console-users.tfvars.example (the placeholder template) IS committed.
console-users*.tfvars
*.auto.tfvars
