# Local Terraform working files — state lives remotely in S3, never commit
# a local copy or provider caches.
.terraform/
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.tfvars
*.tfvars.json
override.tf
override.tf.json
.terraformrc
terraform.rc

# The dependency lock file IS committed on purpose, so every apply (local
# or CI) resolves the exact same provider versions:
# !.terraform.lock.hcl

# Partial backend config: embeds the AWS account id in the state bucket
# name, so it's supplied locally/in CI via -backend-config and never
# committed. backend.hcl.example (the placeholder template) IS committed.
backend.hcl
